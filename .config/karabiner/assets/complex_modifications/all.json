{
  "title": "all",
  "rules": [
    {
      "description": "ctrl + ; to eisuu",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "semicolon",
            "modifiers": {
              "mandatory": ["control"]
            }
          },
          "to": [
            {
              "key_code": "japanese_eisuu"
            }
          ]
        }
      ]
    },
    {
      "description": "control + i to tab",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "i",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "tab"
            }
          ]
        }
      ]
    },
    {
      "description": "c-h to delete_or_backspace",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "delete_or_backspace"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^com\\.googlecode\\.iterm2$",
                "^com\\.github\\.wez\\.wezterm$",
                "^net\\.kovidgoyal\\.kitty$",
                "^org\\.alacritty$",
                "^com\\.mitchellh\\.ghostty$",
                "^dev\\.warp\\.Warp-Stable$",
                "^co\\.zeit\\.hyper$",
                "^org\\.tabby$",
                "^com\\.raphaelamorim\\.rio$",
                "^local\\.weznote$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "fast c-w c-{j,[} strips ctrl in terminal apps",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "j",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "j"
            },
            {
              "set_variable": {
                "name": "terminal_ctrl_w_recent",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^com\\.googlecode\\.iterm2$",
                "^com\\.github\\.wez\\.wezterm$",
                "^net\\.kovidgoyal\\.kitty$",
                "^org\\.alacritty$",
                "^com\\.mitchellh\\.ghostty$",
                "^dev\\.warp\\.Warp-Stable$",
                "^co\\.zeit\\.hyper$",
                "^org\\.tabby$",
                "^com\\.raphaelamorim\\.rio$",
                "^local\\.weznote$"
              ]
            },
            {
              "type": "variable_if",
              "name": "terminal_ctrl_w_recent",
              "value": 1
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "open_bracket",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "open_bracket"
            },
            {
              "set_variable": {
                "name": "terminal_ctrl_w_recent",
                "value": 0
              }
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^com\\.googlecode\\.iterm2$",
                "^com\\.github\\.wez\\.wezterm$",
                "^net\\.kovidgoyal\\.kitty$",
                "^org\\.alacritty$",
                "^com\\.mitchellh\\.ghostty$",
                "^dev\\.warp\\.Warp-Stable$",
                "^co\\.zeit\\.hyper$",
                "^org\\.tabby$",
                "^com\\.raphaelamorim\\.rio$",
                "^local\\.weznote$"
              ]
            },
            {
              "type": "variable_if",
              "name": "terminal_ctrl_w_recent",
              "value": 1
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "w",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "terminal_ctrl_w_recent",
                "value": 1
              }
            },
            {
              "key_code": "w",
              "modifiers": ["control"]
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "terminal_ctrl_w_recent",
                  "value": 0
                }
              }
            ],
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "terminal_ctrl_w_recent",
                  "value": 0
                }
              }
            ]
          },
          "parameters": {
            "basic.to_delayed_action_delay_milliseconds": 180
          },
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^com\\.googlecode\\.iterm2$",
                "^com\\.github\\.wez\\.wezterm$",
                "^net\\.kovidgoyal\\.kitty$",
                "^org\\.alacritty$",
                "^com\\.mitchellh\\.ghostty$",
                "^dev\\.warp\\.Warp-Stable$",
                "^co\\.zeit\\.hyper$",
                "^org\\.tabby$",
                "^com\\.raphaelamorim\\.rio$",
                "^local\\.weznote$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "c-m to return_or_enter",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "m",
            "modifiers": {
              "mandatory": ["control", "command", "option"]
            }
          },
          "to": [
            {
              "key_code": "m",
              "modifiers": ["control", "command", "option"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "m",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "return_or_enter"
            }
          ]
        }
      ]
    },
    {
      "description": "Add eisuu to escape",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "escape"
          },
          "to": [
            {
              "key_code": "japanese_eisuu"
            },
            {
              "key_code": "escape"
            }
          ]
        }
      ]
    },
    {
      "description": "Add eisuu to c-[",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "open_bracket",
            "modifiers": {
              "mandatory": ["control"]
            }
          },
          "to": [
            {
              "key_code": "japanese_eisuu"
            },
            {
              "key_code": "open_bracket",
              "modifiers": ["control"]
            }
          ]
        }
      ]
    },
    {
      "description": "ctrl + , to toggle weznote",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "comma",
            "modifiers": { "mandatory": ["control"], "optional": ["any"] }
          },
          "to": [
            {
              "shell_command": "front_app=$(/usr/bin/lsappinfo info -only bundleid $(/usr/bin/lsappinfo front) | cut -d '\"' -f4); if [ -n \"$front_app\" ]; then echo \"$front_app\" > /tmp/karabiner_previous_app_bundle_id; fi; /usr/bin/osascript -e 'tell application id \"local.weznote\" to activate'"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": ["^local\\.weznote$"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "comma",
            "modifiers": { "mandatory": ["control"], "optional": ["any"] }
          },
          "to": [
            {
              "shell_command": "if [ -f /tmp/karabiner_previous_app_bundle_id ]; then prev_app=$(cat /tmp/karabiner_previous_app_bundle_id); if [ -n \"$prev_app\" ]; then /usr/bin/osascript -e \"tell application id \\\"$prev_app\\\" to activate\"; fi; fi"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^local\\.weznote$"]
            }
          ]
        }
      ]
    }
  ]
}
